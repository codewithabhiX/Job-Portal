<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>JobMingle | Find Your Dream Job</title>

<link rel="stylesheet" href="/css/home.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- Navbar -->

<nav class="navbar">

<div class="logo">
JobMingle
</div>

<ul class="nav-links">
 <% if(role=="candidate"){ %>
    <li><a >Home</a></li>
    <li><a href="/job/">Jobs</a></li>
    <li><a href="/companies">Companies</a></li>
    <li><a href="/user/profile">Profile</a></li>
    <li><a class="logout-btn" href="/user/logout">Logout</a></li>
  <% } else if(role=="recruiter"){ %>
    <li><a >Home</a></li>
    <li><a href="/job/recruiter">View Jobs</a></li>
    <li><a class="logout-btn" href="/user/logout">Logout</a></li>
  <% }else{%>
    <li><a href="/home/">Home</a></li>
    <li><a href="/job/">Jobs</a></li>
    <li><a href="/companies">Companies</a></li>
    <li><a href="/user/login">Login</a></li>
    <li><a class="register-btn" href="/user/register">Register</a></li>
    <% } %>
</ul>

</nav>


<!-- Hero Section -->

<section class="hero">

<div class="hero-content">

<h1>Find Your Dream Job Today</h1>

<p>
Connect with top companies and recruiters across the world.
Discover opportunities that match your skills and passion.
</p>

<div class="hero-buttons">

<a href="/jobs" class="primary-btn">Browse Jobs</a>

<a href="/job/postjob" class="secondary-btn">Post a Job</a>

</div>

</div>

</section>


<!-- Features Section -->

<section class="features">

<h2>Why Choose JobMingle?</h2>

<div class="feature-container">

<div class="feature-box">
<h3>🔎 Smart Job Search</h3>
<p>Find jobs based on skills, location and experience.</p>
</div>

<div class="feature-box">
<h3>🏢 Top Companies</h3>
<p>Connect with top recruiters from leading companies.</p>
</div>

<div class="feature-box">
<h3>⚡ Quick Apply</h3>
<p>Apply to multiple jobs with a single click.</p>
</div>

</div>

</section>


<!-- Stats Section -->

<section class="stats">

<div class="stat">
<h2>10K+</h2>
<p>Jobs Posted</p>
</div>

<div class="stat">
<h2>5K+</h2>
<p>Companies</p>
</div>

<div class="stat">
<h2>20K+</h2>
<p>Candidates</p>
</div>

</section>


<!-- CTA Section -->

<section class="cta">

<h2>Ready to Start Your Career Journey?</h2>

<a href="/register" class="primary-btn">Get Started</a>

</section>


<!-- Footer -->

<footer>

<p>© 2026 JobMingle. All Rights Reserved.</p>

</footer>

<script src="/js/script.js"></script>

</body>
</html>